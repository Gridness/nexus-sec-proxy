# Exact released component version used by both production images.
NEXUS_SEC_PROXY_VERSION=0.1.0 # x-release-please-version

# Required production endpoints.
NEXUS_SEC_PROXY_NEXUS_BASE_URL=http://nexus.example.internal:8081
NEXUS_SEC_PROXY_TRUST_BASE_URL=https://proxy.example.com

# Optional host port and direct credentials. Prefer *_FILE for secrets.
NEXUS_SEC_PROXY_PORT=3000
NEXUS_SEC_PROXY_NEXUS_USERNAME=
NEXUS_SEC_PROXY_NEXUS_PASSWORD=
NEXUS_SEC_PROXY_NEXUS_PASSWORD_FILE=
NEXUS_SEC_PROXY_ADMIN_TOKEN=
NEXUS_SEC_PROXY_YANDEX_MESSENGER_TOKEN=
NEXUS_SEC_PROXY_YANDEX_MESSENGER_TOKEN_FILE=
